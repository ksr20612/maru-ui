{
  "name": "@maru-ui/react-hooks",
  "version": "0.0.1",
  "description": "Reusable React hooks for Maru UI",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@maru-ui/config-typescript": "workspace:*",
    "@maru-ui/core": "workspace:*",
    "@types/react": "^19.0.1",
    "glob": "^13.0.6",
    "react": "^19.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
